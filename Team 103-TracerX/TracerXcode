<script>
const canvas = document.getElementById('network-canvas');
const ctx = canvas.getContext('2d');
const tooltip = document.getElementById('tooltip');

// --- DATA ---
const NODES = [
  { id: 'internet',   label: 'Internet',       type: 'external',  ip: 'External',         os: '—',              ports: '—',         risk: 0,   status: 'neutral',    cves: [] },
  { id: 'fw',         label: 'Firewall',        type: 'secure',    ip: '10.0.0.1',         os: 'FortiOS 7.0',    ports: '443',       risk: 3.2, status: 'Secure',     cves: [] },
  { id: 'dmz-lb',     label: 'Load Balancer',   type: 'vulnerable',ip: '10.0.1.5',         os: 'HAProxy 2.2',    ports: '80,443',    risk: 6.8, status: 'Vulnerable', cves: [{id:'CVE-2021-40346',desc:'Integer overflow in HAProxy (CVSS 8.6)'}] },
  { id: 'web1',       label: 'Web Server',      type: 'critical',  ip: '192.168.1.10',     os: 'Ubuntu 20.04',   ports: '80,443,22', risk: 9.1, status: 'Vulnerable', cves: [{id:'CVE-2021-41773',desc:'Path traversal Apache (CVSS 9.8)'},{id:'CVE-2022-0778',desc:'OpenSSL infinite loop DoS'}] },
  { id: 'web2',       label: 'Web Server 2',    type: 'vulnerable',ip: '192.168.1.11',     os: 'CentOS 7',       ports: '80,443',    risk: 7.2, status: 'Vulnerable', cves: [{id:'CVE-2021-3156',desc:'Sudo heap overflow (CVSS 7.8)'}] },
  { id: 'appsvr',     label: 'App Server',      type: 'critical',  ip: '10.10.0.20',       os: 'RHEL 8.4',       ports: '8080,22',   risk: 8.8, status: 'Vulnerable', cves: [{id:'CVE-2022-22965',desc:'Spring4Shell RCE (CVSS 9.8)'},{id:'CVE-2021-44228',desc:'Log4Shell RCE (CVSS 10.0)'}] },
  { id: 'api',        label: 'API Gateway',     type: 'vulnerable',ip: '10.10.0.30',       os: 'Node 14.18',     ports: '3000,22',   risk: 7.5, status: 'Vulnerable', cves: [{id:'CVE-2022-32213',desc:'Node.js HTTP smuggling (CVSS 6.5)'}] },
  { id: 'db-primary', label: 'Database',        type: 'target',    ip: '10.20.0.10',       os: 'PostgreSQL 13',  ports: '5432',      risk: 9.5, status: 'Critical',   cves: [{id:'CVE-2019-9193',desc:'PostgreSQL COPY TO/FROM arbitrary code exec'}] },
  { id: 'db-backup',  label: 'DB Backup',       type: 'target',    ip: '10.20.0.11',       os: 'PostgreSQL 13',  ports: '5432,22',   risk: 8.2, status: 'Vulnerable', cves: [{id:'CVE-2021-23222',desc:'PostgreSQL Man-in-the-Middle (CVSS 5.9)'}] },
  { id: 'ldap',       label: 'LDAP / AD',       type: 'critical',  ip: '10.30.0.5',        os: 'Windows Server', ports: '389,636',   risk: 8.9, status: 'Vulnerable', cves: [{id:'CVE-2021-42278',desc:'Active Directory privilege escalation'},{id:'CVE-2021-42287',desc:'AD spoofing (CVSS 8.8)'}] },
  { id: 'devops',     label: 'CI/CD Server',    type: 'vulnerable',ip: '10.40.0.5',        os: 'Jenkins 2.303', ports: '8080,22',   risk: 7.9, status: 'Vulnerable', cves: [{id:'CVE-2021-21985',desc:'Jenkins RCE via script console'}] },
  { id: 'mon',        label: 'Monitoring',      type: 'secure',    ip: '10.50.0.5',        os: 'Grafana 8.3',    ports: '3000',      risk: 4.1, status: 'Patched',    cves: [] },
];

const EDGES = [
  { from: 'internet', to: 'fw' },
  { from: 'fw', to: 'dmz-lb' },
  { from: 'dmz-lb', to: 'web1' },
  { from: 'dmz-lb', to: 'web2' },
  { from: 'web1', to: 'appsvr' },
  { from: 'web2', to: 'appsvr' },
  { from: 'appsvr', to: 'api' },
  { from: 'appsvr', to: 'db-primary' },
  { from: 'api', to: 'db-primary' },
  { from: 'api', to: 'db-backup' },
  { from: 'appsvr', to: 'ldap' },
  { from: 'ldap', to: 'db-primary' },
  { from: 'devops', to: 'appsvr' },
  { from: 'devops', to: 'ldap' },
  { from: 'mon', to: 'db-primary' },
  { from: 'mon', to: 'appsvr' },
];

const ATTACK_PATHS = [
  { id: 'AP-001', cvss: 9.8, label: 'Critical', route: ['internet','fw','dmz-lb','web1','appsvr','ldap','db-primary'], vuln: 'Log4Shell → AD PrivEsc → DB Admin', color: '#E24B4A' },
  { id: 'AP-002', cvss: 9.1, label: 'Critical', route: ['internet','fw','dmz-lb','web1','appsvr','db-primary'], vuln: 'Path Traversal → Spring4Shell → DB', color: '#E24B4A' },
  { id: 'AP-003', cvss: 8.8, label: 'High', route: ['internet','fw','dmz-lb','web2','appsvr','api','db-primary'], vuln: 'Sudo Exploit → RCE → DB Breach', color: '#BA7517' },
  { id: 'AP-004', cvss: 8.6, label: 'High', route: ['internet','fw','dmz-lb','web1','appsvr','api','db-backup'], vuln: 'HAProxy Overflow → API → Backup DB', color: '#BA7517' },
  { id: 'AP-005', cvss: 8.1, label: 'High', route: ['internet','fw','devops','appsvr','ldap','db-primary'], vuln: 'Jenkins RCE → AD Spoof → DB', color: '#BA7517' },
  { id: 'AP-006', cvss: 6.5, label: 'Medium', route: ['internet','fw','dmz-lb','api','db-backup'], vuln: 'HTTP Smuggling → API Bypass → DB Read', color: '#854F0B' },
];

// --- Layout ---
const POS = {
  internet:   { x: 0.10, y: 0.50 },
  fw:         { x: 0.22, y: 0.50 },
  'dmz-lb':   { x: 0.35, y: 0.50 },
  web1:       { x: 0.50, y: 0.28 },
  web2:       { x: 0.50, y: 0.65 },
  appsvr:     { x: 0.65, y: 0.28 },
  api:        { x: 0.65, y: 0.65 },
  'db-primary': { x: 0.84, y: 0.42 },
  'db-backup':  { x: 0.84, y: 0.72 },
  ldap:       { x: 0.78, y: 0.14 },
  devops:     { x: 0.36, y: 0.14 },
  mon:        { x: 0.78, y: 0.86 },
};

const NODE_COLORS = {
  critical: { fill: '#FCEBEB', stroke: '#E24B4A', text: '#791F1F' },
  vulnerable: { fill: '#FAEEDA', stroke: '#BA7517', text: '#633806' },
  secure: { fill: '#E6F1FB', stroke: '#185FA5', text: '#042C53' },
  target: { fill: '#EAF3DE', stroke: '#3B6D11', text: '#173404' },
  external: { fill: '#F1EFE8', stroke: '#5F5E5A', text: '#2C2C2A' },
};

let showPaths = true;
let selectedPath = 0;
let selectedNode = null;
let hoveredNode = null;
let animFrame = 0;
let animRunning = true;
let W, H;

function resize() {
  const rect = canvas.parentElement.getBoundingClientRect();
  W = rect.width;
  H = 440;
  canvas.width = W * devicePixelRatio;
  canvas.height = H * devicePixelRatio;
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(devicePixelRatio, devicePixelRatio);
}

function nodePos(id) {
  const p = POS[id];
  return { x: p.x * W, y: p.y * H };
}

function drawEdge(from, to, color, width, alpha, dashed) {
  const a = nodePos(from), b = nodePos(to);
  ctx.save();
  ctx.globalAlpha = alpha;
  ctx.strokeStyle = color;
  ctx.lineWidth = width;
  if (dashed) ctx.setLineDash([6, 4]);
  else ctx.setLineDash([]);
  ctx.beginPath();
  ctx.moveTo(a.x, a.y);
  // gentle curve
  const mx = (a.x + b.x) / 2, my = (a.y + b.y) / 2 - 18;
  ctx.quadraticCurveTo(mx, my, b.x, b.y);
  ctx.stroke();
  // arrow
  const dx = b.x - mx, dy = b.y - my;
  const len = Math.sqrt(dx*dx + dy*dy);
  const ux = dx/len, uy = dy/len;
  const ax = b.x - ux*18, ay = b.y - uy*18;
  ctx.beginPath();
  ctx.moveTo(ax + uy*5, ay - ux*5);
  ctx.lineTo(b.x - ux*14, b.y - uy*14);
  ctx.lineTo(ax - uy*5, ay + ux*5);
  ctx.closePath();
  ctx.fillStyle = color;
  ctx.fill();
  ctx.restore();
}

function drawNode(node, isSelected, isOnPath, pulse) {
  const p = nodePos(node.id);
  const col = NODE_COLORS[node.type];
  const r = node.type === 'target' ? 22 : 18;
  
  ctx.save();
  
  // Pulse ring for selected path nodes
  if (isOnPath && pulse > 0) {
    ctx.globalAlpha = (1 - pulse) * 0.4;
    ctx.strokeStyle = col.stroke;
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.arc(p.x, p.y, r + 8 + pulse * 12, 0, Math.PI * 2);
    ctx.stroke();
  }

  // Outer ring for selected
  if (isSelected) {
    ctx.globalAlpha = 1;
    ctx.strokeStyle = col.stroke;
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.arc(p.x, p.y, r + 5, 0, Math.PI * 2);
    ctx.stroke();
  }

  // Node circle
  ctx.globalAlpha = isOnPath ? 1 : (showPaths ? 0.55 : 1);
  ctx.fillStyle = col.fill;
  ctx.strokeStyle = col.stroke;
  ctx.lineWidth = isOnPath ? 2 : 1;
  ctx.beginPath();
  ctx.arc(p.x, p.y, r, 0, Math.PI * 2);
  ctx.fill();
  ctx.stroke();

  // Icon letter
  ctx.globalAlpha = isOnPath ? 1 : (showPaths ? 0.55 : 1);
  ctx.fillStyle = col.text;
  ctx.font = `500 9px 'JetBrains Mono', monospace`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  const abbr = node.label.split(' ').map(w => w[0]).join('').slice(0,3);
  ctx.fillText(abbr, p.x, p.y);

  // Label below
  ctx.font = `500 10px 'Sora', sans-serif`;
  ctx.fillStyle = isOnPath ? col.text : (showPaths ? '#9c9a92' : col.text);
  ctx.globalAlpha = 1;
  ctx.fillText(node.label, p.x, p.y + r + 11);

  // Risk badge (small)
  if (node.risk > 0 && (isOnPath || !showPaths)) {
    const riskColor = node.risk >= 9 ? '#E24B4A' : node.risk >= 7 ? '#BA7517' : '#3B6D11';
    ctx.fillStyle = riskColor;
    ctx.font = `500 8px 'JetBrains Mono', monospace`;
    ctx.fillText(node.risk.toFixed(1), p.x, p.y + r + 21);
  }
  
  ctx.restore();
}

function drawAnimatedPath(path, t) {
  const route = path.route;
  for (let i = 0; i < route.length - 1; i++) {
    const from = route[i], to = route[i+1];
    const a = nodePos(from), b = nodePos(to);
    const mx = (a.x + b.x) / 2, my = (a.y + b.y) / 2 - 18;

    // Draw path
    ctx.save();
    ctx.strokeStyle = path.color;
    ctx.lineWidth = 2.5;
    ctx.globalAlpha = 0.85;
    ctx.setLineDash([]);
    ctx.beginPath();
    ctx.moveTo(a.x, a.y);
    ctx.quadraticCurveTo(mx, my, b.x, b.y);
    ctx.stroke();
    ctx.restore();

    // Animated dot
    const progress = (t * 0.6 - i * 0.15) % 1;
    if (progress > 0 && progress < 1) {
      const seg = progress;
      // Quadratic bezier point
      const qx = (1-seg)*(1-seg)*a.x + 2*(1-seg)*seg*mx + seg*seg*b.x;
      const qy = (1-seg)*(1-seg)*a.y + 2*(1-seg)*seg*my + seg*seg*b.y;
      ctx.save();
      ctx.globalAlpha = Math.sin(progress * Math.PI);
      ctx.fillStyle = path.color;
      ctx.beginPath();
      ctx.arc(qx, qy, 5, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }
  }
}

let lastT = 0;
function render(ts) {
  if (!animRunning) return;
  const t = ts / 1000;
  const pulse = (Math.sin(t * 2) + 1) / 2;
  
  ctx.clearRect(0, 0, W, H);

  // Draw all edges (faint)
  EDGES.forEach(e => {
    if (!showPaths) drawEdge(e.from, e.to, '#B4B2A9', 1, 0.4, true);
    else drawEdge(e.from, e.to, '#D3D1C7', 0.8, 0.25, true);
  });

  // Draw selected attack path
  if (showPaths) {
    const path = ATTACK_PATHS[selectedPath];
    drawAnimatedPath(path, t);
  }

  // Build set of on-path nodes
  const pathNodes = new Set(showPaths ? ATTACK_PATHS[selectedPath].route : []);

  // Draw nodes
  NODES.forEach(node => {
    const isSelected = selectedNode === node.id;
    const isOnPath = pathNodes.has(node.id);
    drawNode(node, isSelected, isOnPath || !showPaths, pulse);
  });

  requestAnimationFrame(render);
}

// --- Interaction ---
canvas.addEventListener('mousemove', e => {
  const rect = canvas.getBoundingClientRect();
  const mx = e.clientX - rect.left, my = e.clientY - rect.top;
  let found = null;
  NODES.forEach(node => {
    const p = nodePos(node.id);
    const r = node.type === 'target' ? 22 : 18;
    if (Math.hypot(mx - p.x, my - p.y) < r + 4) found = node;
  });
  hoveredNode = found ? found.id : null;
  canvas.style.cursor = found ? 'pointer' : 'default';
  
  if (found) {
    tooltip.style.display = 'block';
    tooltip.style.left = (e.clientX - canvas.getBoundingClientRect().left + 14) + 'px';
    tooltip.style.top = (e.clientY - canvas.getBoundingClientRect().top - 60) + 'px';
    document.getElementById('tt-name').textContent = found.label;
    document.getElementById('tt-info').textContent = found.ip + ' · ' + found.os;
    const rColor = found.risk >= 9 ? '#E24B4A' : found.risk >= 7 ? '#BA7517' : found.risk >= 4 ? '#3B6D11' : '#5F5E5A';
    document.getElementById('tt-risk').innerHTML = `<span style="color:${rColor};font-weight:500">Risk: ${found.risk}/10</span> · ${found.status}`;
  } else {
    tooltip.style.display = 'none';
  }
});

canvas.addEventListener('click', e => {
  if (hoveredNode) {
    selectedNode = hoveredNode;
    updateNodePanel(NODES.find(n => n.id === hoveredNode));
  }
});

function updateNodePanel(node) {
  if (!node) return;
  document.getElementById('sel-name').textContent = node.label;
  document.getElementById('sel-type').textContent = (node.type.toUpperCase()) + ' · ' + node.ip;
  document.getElementById('sel-os').textContent = node.os;
  document.getElementById('sel-ports').textContent = node.ports;
  document.getElementById('sel-risk').textContent = node.risk + ' / 10';
  const rColor = node.risk >= 9 ? '#E24B4A' : node.risk >= 7 ? '#BA7517' : '#3B6D11';
  document.getElementById('sel-risk').style.color = rColor;
  document.getElementById('sel-status').textContent = node.status;
  const dotEl = document.querySelector('#node-panel .status-dot');
  dotEl.className = 'status-dot ' + (node.risk >= 8 ? 'status-vuln' : node.risk >= 5 ? 'status-warn' : 'status-ok');

  const vl = document.getElementById('sel-vulns');
  if (node.cves.length === 0) {
    vl.innerHTML = '<div style="font-size:11px;color:var(--muted);padding:6px 0">No known CVEs</div>';
  } else {
    vl.innerHTML = node.cves.map(c => `
      <div class="vuln-item">
        <span class="vuln-cve">${c.id}</span>
        <span class="vuln-desc">${c.desc}</span>
      </div>`).join('');
  }
}

// --- Build paths list ---
function buildPathsList() {
  const container = document.getElementById('paths-list');
  container.innerHTML = '';
  ATTACK_PATHS.forEach((path, i) => {
    const item = document.createElement('div');
    item.className = 'path-item' + (i === selectedPath ? ' selected' : '');
    item.innerHTML = `
      <div class="path-item-header">
        <span class="path-id">${path.id}</span>
        <span class="cvss-badge ${path.cvss >= 9 ? 'cvss-critical' : path.cvss >= 7 ? 'cvss-high' : 'cvss-medium'}">CVSS ${path.cvss}</span>
      </div>
      <div class="path-route">${path.route.join(' → ')}</div>
      <div class="path-vuln">${path.vuln}</div>`;
    item.onclick = () => selectPath(i);
    container.appendChild(item);
  });
}

function selectPath(i) {
  selectedPath = i;
  buildPathsList();
  document.getElementById('canvas-status').textContent = `Showing ${ATTACK_PATHS[i].id} · CVSS ${ATTACK_PATHS[i].cvss} · ${ATTACK_PATHS[i].label}`;
}

function toggleView(v) {
  showPaths = v === 'paths';
  document.getElementById('btn-paths').classList.toggle('active', showPaths);
  document.getElementById('btn-topo').classList.toggle('active', !showPaths);
  document.getElementById('canvas-status').textContent = showPaths
    ? `6 attack paths computed · hover nodes for details`
    : 'Full topology view · click a node for details';
}

async function runScan() {
  const btn = document.getElementById('scan-btn');
  btn.classList.add('scanning');
  btn.innerHTML = '<div class="scan-spinner"></div> Scanning...';
  document.getElementById('canvas-status').textContent = 'Scanning network...';
  await new Promise(r => setTimeout(r, 1800));
  btn.classList.remove('scanning');
  btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg> Run New Scan`;
  document.getElementById('canvas-status').textContent = 'Scan complete · 6 paths found · threats unchanged';
}

// Init
window.addEventListener('resize', () => { resize(); });
resize();
buildPathsList();
updateNodePanel(NODES.find(n => n.id === 'web1'));
requestAnimationFrame(render);
</script>
