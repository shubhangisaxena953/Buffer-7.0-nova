
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Sora:wght@400;500;600&display=swap');

  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: var(--color-background-tertiary);
    --surface: var(--color-background-secondary);
    --card: var(--color-background-primary);
    --border: var(--color-border-tertiary);
    --border2: var(--color-border-secondary);
    --text: var(--color-text-primary);
    --muted: var(--color-text-secondary);
    --hint: var(--color-text-tertiary);
    --r-md: var(--border-radius-md);
    --r-lg: var(--border-radius-lg);
    --danger: #E24B4A;
    --danger-light: #FCEBEB;
    --warning: #BA7517;
    --warning-light: #FAEEDA;
    --safe: #3B6D11;
    --safe-light: #EAF3DE;
    --info: #185FA5;
    --info-light: #E6F1FB;
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Sora', var(--font-sans), sans-serif;
  }

  body { font-family: var(--sans); background: transparent; color: var(--text); }

  .app { display: flex; flex-direction: column; gap: 0; min-height: 600px; }

  /* Header */
  .header { 
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 0.5px solid var(--border);
    background: var(--card);
  }
  .header-title { display: flex; align-items: center; gap: 10px; }
  .shield-icon { 
    width: 32px; height: 32px; background: var(--danger); border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .shield-icon svg { width: 18px; height: 18px; }
  .header h1 { font-size: 15px; font-weight: 600; letter-spacing: -0.3px; }
  .header p { font-size: 11px; color: var(--muted); font-family: var(--mono); margin-top: 1px; }

  .risk-badge {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 12px; border-radius: 20px;
    font-size: 11px; font-weight: 500; font-family: var(--mono);
  }
  .risk-badge.critical { background: var(--danger-light); color: var(--danger); border: 0.5px solid #F09595; }
  .risk-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; animation: pulse-dot 1.2s ease-in-out infinite; }
  @keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:.3} }

  /* Layout */
  .main { display: grid; grid-template-columns: 1fr 300px; flex: 1; }
  @media (max-width: 700px) { .main { grid-template-columns: 1fr; } }

  /* Canvas panel */
  .canvas-panel {
    position: relative;
    background: var(--surface);
    border-right: 0.5px solid var(--border);
    overflow: hidden;
    min-height: 480px;
  }
  .canvas-toolbar {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 12px;
    background: var(--card);
    border-bottom: 0.5px solid var(--border);
    font-size: 11px; color: var(--muted); font-family: var(--mono);
  }
  .canvas-toolbar span { margin-right: auto; }
  .tb-btn {
    padding: 4px 10px; border-radius: 4px; border: 0.5px solid var(--border2);
    background: var(--surface); color: var(--text); font-size: 11px; cursor: pointer;
    font-family: var(--mono); transition: background .15s;
  }
  .tb-btn:hover { background: var(--card); }
  .tb-btn.active { background: var(--danger-light); color: var(--danger); border-color: #F09595; }

  #network-canvas { 
    width: 100%; height: 440px; display: block;
    cursor: default;
  }

  /* Legend */
  .legend {
    display: flex; flex-wrap: wrap; gap: 12px;
    padding: 8px 12px;
    background: var(--card); border-top: 0.5px solid var(--border);
    font-size: 10px; color: var(--muted);
  }
  .leg-item { display: flex; align-items: center; gap: 5px; }
  .leg-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

  /* Sidebar */
  .sidebar { background: var(--card); display: flex; flex-direction: column; overflow-y: auto; max-height: 560px; }
  .sidebar-section { border-bottom: 0.5px solid var(--border); }
  .sidebar-section-title {
    padding: 10px 14px 6px; font-size: 10px; font-weight: 500;
    color: var(--muted); text-transform: uppercase; letter-spacing: 0.6px;
    font-family: var(--mono);
  }

  /* Attack paths list */
  .path-item {
    padding: 10px 14px; cursor: pointer; border-bottom: 0.5px solid var(--border);
    transition: background .15s;
  }
  .path-item:hover { background: var(--surface); }
  .path-item.selected { background: var(--danger-light); border-left: 3px solid var(--danger); }
  .path-item-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; }
  .path-id { font-family: var(--mono); font-size: 10px; color: var(--muted); }
  .cvss-badge { 
    font-family: var(--mono); font-size: 10px; font-weight: 500;
    padding: 1px 6px; border-radius: 3px;
  }
  .cvss-critical { background: var(--danger-light); color: var(--danger); }
  .cvss-high { background: var(--warning-light); color: var(--warning); }
  .cvss-medium { background: #FAEEDA; color: #854F0B; }
  .path-route { font-size: 11px; font-family: var(--mono); color: var(--text); line-height: 1.6; margin-bottom: 4px; }
  .path-vuln { font-size: 10px; color: var(--muted); }

  /* Node detail */
  .node-detail { padding: 12px 14px; }
  .node-name { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
  .node-type { font-size: 10px; color: var(--muted); font-family: var(--mono); margin-bottom: 10px; }
  .detail-row { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; border-bottom: 0.5px solid var(--border); font-size: 12px; }
  .detail-label { color: var(--muted); }
  .detail-value { font-family: var(--mono); font-size: 11px; }
  .status-dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; margin-right: 5px; }
  .status-vuln { background: var(--danger); }
  .status-ok { background: var(--safe); }
  .status-warn { background: var(--warning); }

  .vuln-list { margin-top: 10px; }
  .vuln-item { 
    padding: 6px 8px; border-radius: var(--r-md); margin-bottom: 5px;
    background: var(--surface); font-size: 11px; font-family: var(--mono);
    border: 0.5px solid var(--border); display: flex; align-items: flex-start; gap: 8px;
  }
  .vuln-cve { color: var(--danger); font-weight: 500; flex-shrink: 0; font-size: 10px; }
  .vuln-desc { color: var(--text); font-size: 10px; }

  /* Stats bar */
  .stats-bar {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-bottom: 0.5px solid var(--border);
  }
  .stat-cell { 
    padding: 10px 14px; text-align: center;
    border-right: 0.5px solid var(--border);
  }
  .stat-cell:last-child { border-right: none; }
  .stat-val { font-size: 18px; font-weight: 600; font-family: var(--mono); line-height: 1; }
  .stat-lbl { font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.4px; margin-top: 2px; }
  .stat-critical { color: var(--danger); }
  .stat-high { color: var(--warning); }
  .stat-nodes { color: var(--info); }
  .stat-paths { color: #534AB7; }

  /* Scan btn */
  .scan-btn {
    display: flex; align-items: center; gap: 8px;
    margin: 12px 14px; padding: 9px 14px;
    background: var(--danger); color: #fff;
    border: none; border-radius: var(--r-md); cursor: pointer;
    font-family: var(--mono); font-size: 12px; font-weight: 500;
    transition: opacity .15s; width: calc(100% - 28px);
    justify-content: center;
  }
  .scan-btn:hover { opacity: .88; }
  .scan-btn.scanning { opacity: .7; pointer-events: none; }
  .scan-spinner { width: 12px; height: 12px; border: 2px solid rgba(255,255,255,.3); border-top-color: #fff; border-radius: 50%; animation: spin .6s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Tooltip */
  .tooltip {
    position: absolute; background: var(--card); border: 0.5px solid var(--border2);
    border-radius: var(--r-md); padding: 8px 12px; font-size: 11px;
    pointer-events: none; display: none; z-index: 10; min-width: 140px;
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
  }
  .tooltip-name { font-weight: 500; margin-bottom: 2px; }
  .tooltip-info { font-size: 10px; color: var(--muted); font-family: var(--mono); }
  .tooltip-risk { font-size: 10px; font-family: var(--mono); margin-top: 4px; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }
</style>

